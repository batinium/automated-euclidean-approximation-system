{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://canb.example/schema/ast.schema.json",
  "title": "CANB AEAS AST v1",
  "description": "Restricted constructible-expression AST used by CANB submissions.",
  "$ref": "#/definitions/node",
  "definitions": {
    "rational": {
      "type": "string",
      "pattern": "^-?(0|[1-9][0-9]*)/[1-9][0-9]*$"
    },
    "node": {
      "oneOf": [
        {
          "type": "object",
          "required": ["op", "value"],
          "additionalProperties": false,
          "properties": {
            "op": {"const": "CONST"},
            "value": {"$ref": "#/definitions/rational"}
          }
        },
        {
          "type": "object",
          "required": ["op", "args"],
          "additionalProperties": false,
          "properties": {
            "op": {"enum": ["NEG", "INV", "SQRT"]},
            "args": {
              "type": "array",
              "minItems": 1,
              "maxItems": 1,
              "items": {"$ref": "#/definitions/node"}
            }
          }
        },
        {
          "type": "object",
          "required": ["op", "args"],
          "additionalProperties": false,
          "properties": {
            "op": {"enum": ["ADD", "SUB", "MUL", "DIV"]},
            "args": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": {"$ref": "#/definitions/node"}
            }
          }
        }
      ]
    }
  }
}
