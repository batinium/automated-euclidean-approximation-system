{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://canb.example/schema/submission.schema.json",
  "title": "CANB Submission v0.1",
  "type": "object",
  "required": [
    "task_id",
    "method",
    "submitted_at",
    "budget",
    "metrics",
    "expression",
    "error_selfreport_dps80"
  ],
  "additionalProperties": false,
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^canb-[a-z0-9-]+$"
    },
    "method": {"type": "string", "minLength": 1},
    "submitted_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "status": {"enum": ["success", "timeout", "failed"]},
    "budget": {
      "type": "object",
      "required": ["max_walltime_sec", "max_memory_mb", "max_evaluations"],
      "additionalProperties": false,
      "properties": {
        "max_walltime_sec": {"type": "number", "exclusiveMinimum": 0},
        "max_memory_mb": {"type": "number", "exclusiveMinimum": 0},
        "max_evaluations": {"type": ["integer", "null"], "minimum": 0}
      }
    },
    "metrics": {
      "type": "object",
      "required": ["walltime_sec", "peak_memory_mb", "num_evaluations"],
      "additionalProperties": false,
      "properties": {
        "walltime_sec": {"type": "number", "minimum": 0},
        "peak_memory_mb": {"type": "number", "minimum": 0},
        "num_evaluations": {"type": ["integer", "null"], "minimum": 0}
      }
    },
    "expression": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "required": ["format", "ast"],
          "additionalProperties": false,
          "properties": {
            "format": {"const": "aeas-ast-v1"},
            "ast": {"$ref": "ast.schema.json"}
          }
        }
      ]
    },
    "error_selfreport_dps80": {
      "type": ["string", "null"],
      "pattern": "^(inf|nan|-?(0|[1-9][0-9]*)(\\.[0-9]+)?([eE][+-]?[0-9]+)?)$"
    },
    "notes": {"type": "string"}
  },
  "allOf": [
    {
      "if": {
        "properties": {"expression": {"type": "null"}}
      },
      "then": {
        "required": ["status"]
      }
    }
  ]
}
